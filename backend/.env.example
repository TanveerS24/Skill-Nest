# Backend .env file - Example Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
# Format: postgresql+asyncpg://username:password@host:port/database
# Note: URL-encode special characters in password (@ = %40, * = %2A)
DATABASE_URL=PostgreSQL connection URL (e.g., postgresql+asyncpg://postgres:password@localhost:5432/skillnest)

# Security
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=Your JWT signing algorithm (e.g., HS256)
ACCESS_TOKEN_EXPIRE_MINUTES=Expiration time for access tokens in minutes (e.g., 1440 for 1 day)

# Application
DEBUG=True | False
API_V1_PREFIX=API version prefix (e.g., /api/v1)

# RAG Configuration (AI-powered language detection)
OLLAMA_BASE_URL=Ollama server URL (e.g., http://localhost:11434)
OLLAMA_MODEL=Ollama model name (e.g., llama3.2:3b-instruct-q4_K_M)
EMBED_MODEL=Embedding model name (e.g., nomic-embed-text)
CHROMA_PERSIST_DIR=ChromaDB persistence directory (e.g., ./chroma_db)

# Docker Execution Settings
DOCKER_MEMORY_LIMIT=Memory limit for code execution containers (e.g., 256m)
DOCKER_CPU_LIMIT=CPU limit for code execution containers (e.g., 0.5)
EXECUTION_TIMEOUT=Timeout in seconds for code execution (e.g., 2)
MAX_CODE_SIZE=Maximum allowed code size in bytes (e.g., 50000)

# Rate Limiting
RATE_LIMIT_SUBMISSIONS=Submission rate limit (e.g., 10/minute)
