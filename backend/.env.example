# For Docker: use service names (postgres, redis)
DATABASE_URL=postgresql+asyncpg://skillnest:skillnest123@postgres:5432/skillnest
REDIS_URL=redis://redis:6379/0

# For local development: use localhost
# DATABASE_URL=postgresql+asyncpg://skillnest:skillnest123@localhost:5432/skillnest
# REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AI_API_KEY=your-openai-api-key-or-other-ai-service
AI_API_URL=https://api.openai.com/v1/chat/completions
