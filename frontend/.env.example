# Frontend .env file - Example Configuration
# Copy this file to .env and update with your actual values

# API Configuration
# Backend API URL - change this if your backend runs on a different host/port
VITE_API_BASE_URL=Your Backend API URL (e.g., http://localhost:8000/api/v1)

# Application
VITE_APP_NAME=Application name (e.g., SkillNest)
VITE_APP_DESCRIPTION=Application description (e.g., Multi-Language Coding Platform)
